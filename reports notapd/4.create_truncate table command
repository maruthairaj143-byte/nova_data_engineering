-- =============================================================

-- ─────────────────────────────────────────────
-- GOLD: dim_client
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.dim_client (
    client_key    VARCHAR(20)  PRIMARY KEY,
    first_name    VARCHAR(50),
    last_name     VARCHAR(50),
    dob           DATE,
    gender        VARCHAR(10),
    city          VARCHAR(50),
    state         VARCHAR(50),
    blood_group   VARCHAR(5),
    mobile_number VARCHAR(15)  NOT NULL UNIQUE,
    created_by    VARCHAR(50)  DEFAULT 'system',
    created_at    TIMESTAMP    DEFAULT NOW(),
    updated_by    VARCHAR(50)  DEFAULT 'system',
    updated_at    TIMESTAMP    DEFAULT NOW(),
    batch_id      INTEGER      DEFAULT 0
);

-- ─────────────────────────────────────────────
-- public: dim_event
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.dim_event (
    event_key      VARCHAR(20)   PRIMARY KEY,
    event_name     VARCHAR(100)  NOT NULL UNIQUE,
    marathon_type  VARCHAR(20),
    organizer_name VARCHAR(100),
    venue_name     VARCHAR(100),
    event_status   VARCHAR(30),
    event_category VARCHAR(50),
    created_by     VARCHAR(50)   DEFAULT 'system',
    created_at     TIMESTAMP     DEFAULT NOW(),
    updated_by     VARCHAR(50)   DEFAULT 'system',
    updated_at     TIMESTAMP     DEFAULT NOW(),
    batch_id       INTEGER       DEFAULT 0
);

-- ─────────────────────────────────────────────
-- public: dim_location
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.dim_location (
    location_key VARCHAR(20)  PRIMARY KEY,
    city         VARCHAR(50),
    state        VARCHAR(50),
    country      VARCHAR(50),
    created_by   VARCHAR(50)  DEFAULT 'system',
    created_at   TIMESTAMP    DEFAULT NOW(),
    updated_by   VARCHAR(50)  DEFAULT 'system',
    updated_at   TIMESTAMP    DEFAULT NOW(),
    batch_id     INTEGER      DEFAULT 0,
    UNIQUE (city, state)
);

-- ─────────────────────────────────────────────
-- public: dim_sponsor
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.dim_sponsor (
    sponsor_key         VARCHAR(20)   PRIMARY KEY,
    sponsor_name        VARCHAR(100)  NOT NULL UNIQUE,
    sponsor_type        VARCHAR(50),
    contribution_amount NUMERIC(12,2),
    created_by          VARCHAR(50)   DEFAULT 'system',
    created_at          TIMESTAMP     DEFAULT NOW(),
    updated_by          VARCHAR(50)   DEFAULT 'system',
    updated_at          TIMESTAMP     DEFAULT NOW(),
    batch_id            INTEGER       DEFAULT 0
);

-- ─────────────────────────────────────────────
-- public: dim_date
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.dim_date (
    date_key     VARCHAR(20)  PRIMARY KEY,
    date         DATE         NOT NULL UNIQUE,
    day          INTEGER,
    week         INTEGER,
    month        INTEGER,
    quarter      INTEGER,
    year         INTEGER,
    weekend_flag BOOLEAN,
    holiday_flag BOOLEAN,
    created_by   VARCHAR(50)  DEFAULT 'system',
    created_at   TIMESTAMP    DEFAULT NOW(),
    updated_by   VARCHAR(50)  DEFAULT 'system',
    updated_at   TIMESTAMP    DEFAULT NOW(),
    batch_id     INTEGER      DEFAULT 0
);

-- ─────────────────────────────────────────────
-- public: fact_race_result
-- ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.fact_race_result (
    client_key       VARCHAR(20),
    event_key        VARCHAR(20),
    date_key         VARCHAR(20),
    sponsor_key      VARCHAR(20),
    location_key     VARCHAR(20),
    finish_time      INTERVAL,
    rank             INTEGER,
    distance         VARCHAR(20),
    timing_chip_data TEXT,
    created_by       VARCHAR(50)  DEFAULT 'system',
    created_at       TIMESTAMP    DEFAULT NOW(),
    updated_by       VARCHAR(50)  DEFAULT 'system',
    updated_at       TIMESTAMP    DEFAULT NOW(),
    batch_id         INTEGER      DEFAULT 0,
    PRIMARY KEY (client_key, event_key)
);


