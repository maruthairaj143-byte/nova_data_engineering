-- =============================================================
--  ROW COUNT — All tables at a glance
-- =============================================================

SELECT 'public.raw_client'       AS table_name, COUNT(*) AS row_count FROM public.raw_client
UNION ALL
SELECT 'public.raw_result',                      COUNT(*) FROM public.raw_result
UNION ALL
SELECT 'public.raw_event',                        COUNT(*) FROM public.raw_event
UNION ALL
SELECT 'public.client_all',                       COUNT(*) FROM public.client_all
UNION ALL
SELECT 'public.result_all',                       COUNT(*) FROM public.result_all
UNION ALL
SELECT 'public.event_all',                        COUNT(*) FROM public.event_all
UNION ALL
SELECT 'public.stg_client_result',                COUNT(*) FROM public.stg_client_result
UNION ALL
SELECT 'public.stg_event',                        COUNT(*) FROM public.stg_event
UNION ALL
SELECT 'gold.dim_client',                         COUNT(*) FROM gold.dim_client
UNION ALL
SELECT 'gold.dim_event',                          COUNT(*) FROM gold.dim_event
UNION ALL
SELECT 'gold.dim_location',                       COUNT(*) FROM gold.dim_location
UNION ALL
SELECT 'gold.dim_sponsor',                        COUNT(*) FROM gold.dim_sponsor
UNION ALL
SELECT 'gold.dim_date',                           COUNT(*) FROM gold.dim_date
UNION ALL
SELECT 'gold.fact_race_result',                   COUNT(*) FROM gold.fact_race_result
ORDER BY table_name;


